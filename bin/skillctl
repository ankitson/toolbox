#!/usr/bin/env python3
"""Manage external skill snapshots copied into the canonical skills tree."""

from __future__ import annotations

import argparse
import json
import re
import shutil
from string import Template
import subprocess
import sys
import tempfile
from pathlib import Path
from typing import Any


SKILL_NAME = re.compile(r"^[a-z0-9][a-z0-9_-]*$")
GLOB_SOURCE_MARKER = ".skillctl-source"
GLOB_CHARS = frozenset("*?[{")
TOOL_ROOT = Path(__file__).resolve().parent.parent
ROUTER_TEMPLATE = TOOL_ROOT / "templates" / "skillctl" / "router.SKILL.md"


def _is_glob(path: str) -> bool:
    return any(c in path for c in GLOB_CHARS)


def _expand_braces(pattern: str) -> list[str]:
    """Expand one level of {a,b,c} brace syntax into multiple patterns."""
    m = re.search(r"\{([^{}]+)\}", pattern)
    if not m:
        return [pattern]
    prefix, suffix = pattern[: m.start()], pattern[m.end():]
    alts = [a.strip() for a in m.group(1).split(",")]
    result: list[str] = []
    for alt in alts:
        result.extend(_expand_braces(prefix + alt + suffix))
    return result


def _title_from_name(name: str) -> str:
    return " ".join(part.capitalize() for part in re.split(r"[-_]+", name) if part)


def _frontmatter_value(value: str) -> str:
    value = value.strip()
    if len(value) >= 2 and value[0] == value[-1] and value[0] in {"'", '"'}:
        return value[1:-1]
    return value


def _name_from_absorb(spec: str) -> str:
    path = spec.split(":", 1)[-1].rstrip("/")
    return path.rsplit("/", 1)[-1]


class SkillctlError(RuntimeError):
    """An expected user-facing failure."""


def run(*args: str, cwd: Path | None = None) -> str:
    try:
        completed = subprocess.run(
            args,
            cwd=cwd,
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
        )
    except FileNotFoundError as exc:
        raise SkillctlError(f"required command not found: {args[0]}") from exc
    except subprocess.CalledProcessError as exc:
        detail = exc.stderr.strip() or exc.stdout.strip()
        raise SkillctlError(f"{' '.join(args)} failed: {detail}") from exc
    return completed.stdout.strip()


def render_template(path: Path, values: dict[str, str]) -> str:
    try:
        template = Template(path.read_text())
    except OSError as exc:
        raise SkillctlError(f"cannot read template {path}: {exc}") from exc
    try:
        return template.substitute(values)
    except (KeyError, ValueError) as exc:
        raise SkillctlError(f"cannot render template {path}: {exc}") from exc


class SkillManager:
    def __init__(self, root: Path) -> None:
        self.root = root.resolve()
        self.registry_path = self.root / "skills.toml"
        self.skills_dir = self.root / "skills"
        self.sources, self.routers = self.load_registry()

    def load_registry(self) -> tuple[dict[str, dict[str, Any]], dict[str, dict[str, Any]]]:
        if not self.registry_path.exists():
            return {}, {}
        try:
            return self.parse_registry(self.registry_path.read_text())
        except (OSError, ValueError) as exc:
            raise SkillctlError(f"cannot read {self.registry_path}: {exc}") from exc

    @staticmethod
    def parse_registry(content: str) -> tuple[dict[str, dict[str, Any]], dict[str, dict[str, Any]]]:
        """Parse the small TOML subset emitted by save_registry."""
        sources: dict[str, dict[str, Any]] = {}
        routers: dict[str, dict[str, Any]] = {}
        current: dict[str, Any] | None = None
        for line_number, raw_line in enumerate(content.splitlines(), 1):
            line = raw_line.strip()
            if not line or line.startswith("#"):
                continue
            table = re.fullmatch(r"\[(skills|routers)\.([a-z0-9][a-z0-9_-]*)\]", line)
            if table:
                section, name = table.groups()
                registry = sources if section == "skills" else routers
                if name in registry:
                    raise ValueError(f"line {line_number}: duplicate {section} table {name!r}")
                current = registry.setdefault(name, {})
                continue
            if current is None:
                raise ValueError(f"line {line_number}: expected [skills.<name>] or [routers.<name>] table")
            assignment = re.fullmatch(r"([a-z_]+)\s*=\s*(.+)", line)
            if not assignment:
                raise ValueError(f"line {line_number}: expected key = value")
            key, value = assignment.groups()
            if key in current:
                raise ValueError(f"line {line_number}: duplicate key {key!r}")
            try:
                current[key] = json.loads(value)
            except json.JSONDecodeError as exc:
                raise ValueError(f"line {line_number}: value must use TOML basic strings or arrays") from exc
        return sources, routers

    def save_registry(self) -> None:
        lines = [
            "# Authoritative external skill sources and generated router bundles.",
            "# Standalone [skills.*] entries materialize as top-level skills.",
            "# [routers.*].absorbs entries materialize inside router references.",
        ]
        for name, source in sorted(self.sources.items()):
            lines.extend(["", f"[skills.{name}]"])
            for key in ("repo", "ref", "path", "files"):
                if key in source:
                    lines.append(f"{key} = {json.dumps(source[key])}")
        for name, router in sorted(self.routers.items()):
            lines.extend(["", f"[routers.{name}]"])
            for key in ("title", "description", "absorbs"):
                if key in router:
                    lines.append(f"{key} = {json.dumps(router[key])}")
        self.registry_path.write_text("\n".join(lines) + "\n")

    @staticmethod
    def validate_name(name: str) -> None:
        if not SKILL_NAME.fullmatch(name) or name.startswith("."):
            raise SkillctlError(f"invalid skill name: {name!r}")

    @staticmethod
    def repo_url(repo: str) -> str:
        if re.fullmatch(r"[^/:@\s]+/[^/\s]+", repo):
            return f"https://github.com/{repo}.git"
        return repo

    @staticmethod
    def child_path(parent: Path, relative: str, label: str) -> Path:
        candidate = (parent / relative).resolve()
        try:
            candidate.relative_to(parent.resolve())
        except ValueError as exc:
            raise SkillctlError(f"{label} escapes its source checkout: {relative}") from exc
        return candidate

    @staticmethod
    def default_name_from_repo(repo: str) -> str:
        repo = repo.rstrip("/")
        repo = repo.removesuffix(".git")
        name = repo.rsplit("/", 1)[-1]
        return name

    def resolve_source_dir(self, checkout: Path, name: str, source: dict[str, Any]) -> Path:
        if source.get("path"):
            return self.child_path(checkout, source["path"], f"{name}: path")

        candidates = [
            checkout,
            checkout / "skills" / name,
            checkout / name,
        ]
        for candidate in candidates:
            if (candidate / "SKILL.md").is_file():
                return candidate

        discovered: list[Path] = []
        for parent in (checkout / "skills", checkout):
            if not parent.is_dir():
                continue
            for child in parent.iterdir():
                if child.is_dir() and not child.name.startswith(".") and (child / "SKILL.md").is_file():
                    discovered.append(child)
        unique = sorted(set(discovered))
        if len(unique) == 1:
            return unique[0]
        if not unique:
            raise SkillctlError(
                f"{name}: could not find SKILL.md at repo root, skills/{name}, or {name}"
            )
        choices = ", ".join(str(path.relative_to(checkout)) for path in unique)
        raise SkillctlError(f"{name}: multiple skill folders found; pass a path ({choices})")

    @staticmethod
    def parse_absorb_spec(spec: str) -> tuple[str, str]:
        if ":" not in spec:
            raise SkillctlError(f"invalid absorb spec {spec!r}; expected repo:path")
        repo, path = spec.split(":", 1)
        if not repo or not path:
            raise SkillctlError(f"invalid absorb spec {spec!r}; expected repo:path")
        return repo, path

    def resolve_absorb_sources(self, specs: list[str], temporary: Path) -> dict[str, Path]:
        grouped: dict[tuple[str, str], list[tuple[str, str]]] = {}
        for spec in specs:
            if not isinstance(spec, str) or not spec:
                raise SkillctlError("router absorbs must be non-empty strings")
            repo, path = self.parse_absorb_spec(spec)
            skill_name = _name_from_absorb(spec)
            self.validate_name(skill_name)
            grouped.setdefault((repo, path), []).append((skill_name, spec))

        result: dict[str, Path] = {}
        for index, ((repo, path), entries) in enumerate(grouped.items()):
            if repo == "local":
                source_dir = self.child_path(self.root, path, "local absorb")
                if not (source_dir / "SKILL.md").is_file():
                    raise SkillctlError(f"local:{path}: source does not contain SKILL.md")
                for skill_name, _spec in entries:
                    result[skill_name] = source_dir
                continue
            checkout = temporary / f"repo-{index}"
            run("git", "clone", "--quiet", self.repo_url(repo), str(checkout))
            run("git", "checkout", "--quiet", "--detach", "main", cwd=checkout)
            source = {"repo": repo, "path": path}
            if _is_glob(path):
                matched = dict(self.resolve_glob_dirs(checkout, repo, source))
                for skill_name, spec in entries:
                    if skill_name not in matched:
                        raise SkillctlError(f"{spec}: matched no skill named {skill_name}")
                    result[skill_name] = matched[skill_name]
            else:
                source_dir = self.child_path(checkout, path, f"{repo}: path")
                if not (source_dir / "SKILL.md").is_file():
                    raise SkillctlError(f"{repo}:{path}: source does not contain SKILL.md")
                for skill_name, _spec in entries:
                    result[skill_name] = source_dir
        return result

    def router_by_name(self, name: str) -> dict[str, Any]:
        router = self.routers.get(name)
        if router is None:
            raise SkillctlError(f"router not registered: {name}")
        return router

    def validate_router_source(self, name: str, router: Any) -> list[str]:
        errors: list[str] = []
        try:
            self.validate_name(name)
        except SkillctlError as exc:
            return [str(exc)]
        if not isinstance(router, dict):
            return [f"{name}: router must be a TOML table"]
        allowed = {"title", "description", "absorbs"}
        unknown = sorted(set(router) - allowed)
        if unknown:
            errors.append(f"{name}: unknown router keys: {', '.join(unknown)}")
        for key in ("title", "description"):
            if key in router and (not isinstance(router[key], str) or not router[key]):
                errors.append(f"{name}: {key} must be a non-empty string")
        absorbs = router.get("absorbs")
        if (
            not isinstance(absorbs, list)
            or not absorbs
            or not all(isinstance(item, str) and item for item in absorbs)
        ):
            errors.append(f"{name}: absorbs must be a non-empty string array")
        else:
            for spec in absorbs:
                try:
                    self.parse_absorb_spec(spec)
                    self.validate_name(_name_from_absorb(spec))
                except SkillctlError as exc:
                    errors.append(f"{name}: {exc}")
        return errors

    def resolve_glob_dirs(self, checkout: Path, label: str, source: dict[str, Any]) -> list[tuple[str, Path]]:
        """Expand brace patterns and glob to find all matched (skill_name, skill_dir) pairs."""
        pattern = source["path"]
        expanded_patterns = _expand_braces(pattern)
        results: list[tuple[str, Path]] = []
        for pat in expanded_patterns:
            for matched in sorted(checkout.glob(pat)):
                if matched.is_dir() and (matched / "SKILL.md").is_file():
                    skill_name = matched.name
                    results.append((skill_name, matched))
        if not results:
            raise SkillctlError(f"{label}: glob pattern {pattern!r} matched no directories with SKILL.md")
        return results

    def _glob_owned_skills(self, label: str) -> list[str]:
        """Return skill names whose .skillctl-source marker contains label."""
        owned: list[str] = []
        if not self.skills_dir.exists():
            return owned
        for skill_dir in self.skills_dir.iterdir():
            if skill_dir.name.startswith(".") or not skill_dir.is_dir():
                continue
            marker = skill_dir / GLOB_SOURCE_MARKER
            if marker.is_file() and marker.read_text().strip() == label:
                owned.append(skill_dir.name)
        return owned

    def read_skill_metadata_file(self, skill_file: Path, name: str) -> dict[str, str]:
        if not skill_file.is_file():
            raise SkillctlError(f"{name}: SKILL.md is missing")
        metadata = {"name": name, "description": ""}
        lines = skill_file.read_text().splitlines()
        if not lines or lines[0].strip() != "---":
            return metadata
        for line in lines[1:]:
            if line.strip() == "---":
                break
            match = re.fullmatch(r"([A-Za-z0-9_-]+):\s*(.*)", line)
            if match and match.group(1) in metadata:
                metadata[match.group(1)] = _frontmatter_value(match.group(2))
        return metadata

    def read_skill_metadata(self, name: str) -> dict[str, str]:
        return self.read_skill_metadata_file(self.target(name) / "SKILL.md", name)

    def router_source_dir(self, router_name: str, skill_name: str) -> Path:
        active = self.target(skill_name)
        if (active / "SKILL.md").is_file():
            return active
        bundled = self.target(router_name) / "references" / skill_name
        if (bundled / "instructions.md").is_file():
            return bundled
        raise SkillctlError(f"{skill_name}: installed skill or bundled router reference not found")

    def router_source_metadata(self, source_dir: Path, skill_name: str) -> dict[str, str]:
        if (source_dir / "SKILL.md").is_file():
            return self.read_skill_metadata_file(source_dir / "SKILL.md", skill_name)
        return self.read_skill_metadata_file(source_dir / "instructions.md", skill_name)

    def resolve_skills_sh_path(self, path: Path) -> Path:
        if path.is_absolute():
            return path
        return self.root / path

    def skills_from_group(self, group: str, skills_sh: Path) -> tuple[list[str], str, str]:
        manifest_path = self.resolve_skills_sh_path(skills_sh)
        try:
            manifest = json.loads(manifest_path.read_text())
        except FileNotFoundError as exc:
            raise SkillctlError(f"skills.sh manifest not found: {manifest_path}") from exc
        except (OSError, json.JSONDecodeError) as exc:
            raise SkillctlError(f"cannot read {manifest_path}: {exc}") from exc
        if not isinstance(manifest, dict):
            raise SkillctlError(f"{manifest_path}: expected a JSON object")
        groupings = manifest.get("groupings", [])
        if not isinstance(groupings, list):
            raise SkillctlError(f"{manifest_path}: groupings must be an array")

        matches = [
            item
            for item in groupings
            if isinstance(item, dict) and item.get("title") == group
        ]
        if not matches:
            folded = group.casefold()
            matches = [
                item
                for item in groupings
                if isinstance(item, dict)
                and isinstance(item.get("title"), str)
                and item["title"].casefold() == folded
            ]
        if not matches:
            raise SkillctlError(f"{manifest_path}: grouping not found: {group!r}")
        if len(matches) > 1:
            raise SkillctlError(f"{manifest_path}: grouping title is ambiguous: {group!r}")

        matched = matches[0]
        title = matched.get("title")
        description = matched.get("description", "")
        skills = matched.get("skills")
        if not isinstance(title, str) or not title:
            raise SkillctlError(f"{manifest_path}: grouping {group!r} title must be a string")
        if not isinstance(description, str):
            raise SkillctlError(f"{manifest_path}: grouping {title!r} description must be a string")
        if (
            not isinstance(skills, list)
            or not skills
            or not all(isinstance(item, str) and item for item in skills)
        ):
            raise SkillctlError(f"{manifest_path}: grouping {title!r} skills must be a non-empty string array")
        return skills, title, description

    def validate_source(self, name: str, source: Any) -> list[str]:
        errors: list[str] = []
        try:
            self.validate_name(name)
        except SkillctlError as exc:
            return [str(exc)]
        if not isinstance(source, dict):
            return [f"{name}: source must be a TOML table"]
        allowed = {"repo", "ref", "path", "files"}
        unknown = sorted(set(source) - allowed)
        if unknown:
            errors.append(f"{name}: unknown keys: {', '.join(unknown)}")
        if not isinstance(source.get("repo"), str) or not source["repo"]:
            errors.append(f"{name}: repo must be a non-empty string")
        for key in ("ref", "path"):
            if key in source and (not isinstance(source[key], str) or not source[key]):
                errors.append(f"{name}: {key} must be a non-empty string")
        if "files" in source:
            files = source["files"]
            if (
                not isinstance(files, list)
                or not files
                or not all(isinstance(item, str) and item for item in files)
            ):
                errors.append(f"{name}: files must be a non-empty string array")
        # Conflict: files + glob path
        if "files" in source and source.get("path") and _is_glob(source["path"]):
            errors.append(f"{name}: files cannot be combined with a glob path")
        return errors

    def target(self, name: str) -> Path:
        return self.skills_dir / name

    def add(
        self,
        source_arg: str,
        repo_arg: str | None,
        ref: str,
        path: str | None,
        files: list[str],
    ) -> None:
        if repo_arg is None:
            repo = source_arg
            name = self.default_name_from_repo(repo)
        else:
            name = source_arg
            repo = repo_arg
        self.validate_name(name)
        if name in self.sources:
            raise SkillctlError(f"external skill already registered: {name}")
        # Only refuse to overwrite when path is NOT a glob (glob creates multiple dirs, no single target)
        is_glob_path = path is not None and _is_glob(path)
        if not is_glob_path:
            target = self.target(name)
            if target.exists() or target.is_symlink():
                raise SkillctlError(f"refusing to overwrite existing skill: {target}")
        source: dict[str, Any] = {"repo": repo}
        if ref != "main":
            source["ref"] = ref
        if path not in (None, "", "."):
            source["path"] = path
        if files:
            source["files"] = files
        errors = self.validate_source(name, source)
        if errors:
            raise SkillctlError("\n".join(errors))
        self.sync_one(name, source)
        self.sources[name] = source
        self.save_registry()

    def sync(self, names: list[str]) -> None:
        selected = names or sorted(set(self.sources) | set(self.routers))
        selected_sources = [name for name in selected if name in self.sources]
        selected_routers = [name for name in selected if name in self.routers]
        unknown = sorted(set(selected) - set(selected_sources) - set(selected_routers))
        if unknown:
            raise SkillctlError(f"skill or router not registered: {', '.join(unknown)}")
        for name in selected_sources:
            source = self.sources.get(name)
            errors = self.validate_source(name, source)
            if errors:
                raise SkillctlError("\n".join(errors))
            self.sync_one(name, source)
        for name in selected_routers:
            self.sync_router(name)
        self.write_skills_sh()

    def sync_router(self, name: str) -> None:
        self.router(name, [], None, None, Path("skills.sh.json"), None, True, True)

    def write_skills_sh(self) -> None:
        groupings = []
        for name, router in sorted(self.routers.items()):
            errors = self.validate_router_source(name, router)
            if errors:
                raise SkillctlError("\n".join(errors))
            groupings.append(
                {
                    "title": router.get("title") or _title_from_name(name),
                    "description": router.get("description", ""),
                    "skills": [_name_from_absorb(spec) for spec in router["absorbs"]],
                }
            )
        manifest = {
            "$schema": "https://skills.sh/schemas/skills.sh.schema.json",
            "notGrouped": "bottom",
            "groupings": groupings,
        }
        (self.root / "skills.sh.json").write_text(json.dumps(manifest, indent=2) + "\n")

    def _sync_glob(self, label: str, source: dict[str, Any]) -> None:
        """Sync a glob source entry, installing/updating/removing matched skill dirs."""
        self.skills_dir.mkdir(parents=True, exist_ok=True)
        with tempfile.TemporaryDirectory(prefix="skillctl-") as temporary:
            checkout = Path(temporary) / "repo"
            run("git", "clone", "--quiet", self.repo_url(source["repo"]), str(checkout))
            run("git", "checkout", "--quiet", "--detach", source.get("ref", "main"), cwd=checkout)
            revision = run("git", "rev-parse", "HEAD", cwd=checkout)

            matched = self.resolve_glob_dirs(checkout, label, source)
            new_names = {skill_name for skill_name, _ in matched}

            # Install/update each matched skill dir
            for skill_name, source_dir in matched:
                target = self.target(skill_name)
                if target.is_symlink() or target.is_file():
                    target.unlink()
                elif target.exists():
                    shutil.rmtree(target)
                shutil.copytree(source_dir, target, ignore=shutil.ignore_patterns(".git"))
                # Write the source marker
                (target / GLOB_SOURCE_MARKER).write_text(label)
                print(f"synced {skill_name} (from {label}): {revision[:12]}")

            # Remove stale skills previously owned by this label
            previously_owned = self._glob_owned_skills(label)
            for stale_name in previously_owned:
                if stale_name not in new_names:
                    stale_target = self.target(stale_name)
                    if stale_target.exists():
                        shutil.rmtree(stale_target)

    def _sync_single(self, name: str, source: dict[str, Any]) -> None:
        """Sync a single (non-glob) skill source."""
        self.skills_dir.mkdir(parents=True, exist_ok=True)
        with tempfile.TemporaryDirectory(prefix="skillctl-") as temporary:
            checkout = Path(temporary) / "repo"
            run("git", "clone", "--quiet", self.repo_url(source["repo"]), str(checkout))
            run("git", "checkout", "--quiet", "--detach", source.get("ref", "main"), cwd=checkout)
            revision = run("git", "rev-parse", "HEAD", cwd=checkout)
            source_dir = self.resolve_source_dir(checkout, name, source)
            staged = Path(temporary) / "skill"
            files = source.get("files", [])
            if files:
                staged.mkdir()
                for relative in files:
                    source_file = self.child_path(source_dir, relative, f"{name}: file")
                    if not source_file.is_file():
                        raise SkillctlError(f"{name}: source file not found: {relative}")
                    destination = self.child_path(staged, relative, f"{name}: file")
                    destination.parent.mkdir(parents=True, exist_ok=True)
                    shutil.copy2(source_file, destination)
            else:
                if not source_dir.is_dir():
                    raise SkillctlError(f"{name}: source directory not found: {source_dir}")
                shutil.copytree(source_dir, staged, ignore=shutil.ignore_patterns(".git"))
            if not (staged / "SKILL.md").is_file():
                raise SkillctlError(f"{name}: source does not contain SKILL.md")
            target = self.target(name)
            if target.is_symlink() or target.is_file():
                target.unlink()
            elif target.exists():
                shutil.rmtree(target)
            shutil.copytree(staged, target)
        print(f"synced {name}: {revision[:12]}")

    def sync_one(self, name: str, source: dict[str, Any]) -> None:
        if _is_glob(source.get("path", "")):
            self._sync_glob(name, source)
        else:
            self._sync_single(name, source)

    def router(
        self,
        name: str,
        skill_names: list[str],
        source_group: str | None,
        group: str | None,
        skills_sh: Path,
        description: str | None,
        overwrite: bool,
        absorb: bool,
    ) -> None:
        self.validate_name(name)
        selected = set(skill_names)
        group_title = ""
        group_description = ""
        absorb_specs: list[str] = []
        registered_router = self.routers.get(name)
        if registered_router and not (skill_names or source_group or group):
            errors = self.validate_router_source(name, registered_router)
            if errors:
                raise SkillctlError("\n".join(errors))
            group_title = registered_router.get("title", "")
            group_description = registered_router.get("description", "")
            absorb_specs = list(registered_router["absorbs"])
            selected.update(_name_from_absorb(spec) for spec in absorb_specs)
        if group:
            grouped_skills, group_title, group_description = self.skills_from_group(group, skills_sh)
            selected.update(grouped_skills)
        if source_group:
            selected.update(self._glob_owned_skills(source_group))
        if not selected:
            hint = " from selected groups" if source_group or group else ""
            raise SkillctlError(f"{name}: no skills selected{hint}")

        ordered = sorted(selected)
        with tempfile.TemporaryDirectory(prefix="skillctl-router-") as temporary_string:
            temporary_root = Path(temporary_string)
            source_dirs: dict[str, Path] = {}
            if absorb_specs:
                source_dirs.update(self.resolve_absorb_sources(absorb_specs, temporary_root / "absorbs"))
            for skill_name in ordered:
                self.validate_name(skill_name)
                if skill_name not in source_dirs:
                    source_dirs[skill_name] = self.router_source_dir(name, skill_name)

            target = self.target(name)
            if target.exists() or target.is_symlink():
                if not overwrite:
                    raise SkillctlError(f"refusing to overwrite existing skill: {target}")

            metadata = [
                (skill_name, self.router_source_metadata(source_dirs[skill_name], skill_name))
                for skill_name in ordered
            ]
            router_title = group_title or _title_from_name(name)
            if description:
                router_description = description
            elif group_description:
                router_description = f"Route {group_title} requests. {group_description}"
            else:
                router_description = (
                    f"Route requests across the {router_title} skill bundle. Use when a user asks "
                    "for help covered by its bundled reference skills and the exact workflow is unclear."
                )

            routing_rows = []
            for skill_name, data in metadata:
                intent = data["description"] or f"Use the {data['name']} workflow."
                routing_rows.append(f"| {intent} | `references/{skill_name}/instructions.md` |")

            source_notes = []
            if registered_router and not (skill_names or source_group or group):
                source_notes.append(f"Generated from skills.toml router `{name}`.")
            elif group_title:
                source_notes.append(f"Generated from skills.sh.json grouping `{group_title}`.")
            if source_group:
                source_notes.append(f"Generated from source group `{source_group}`.")
            source_note = "\n".join(source_notes)
            if source_note:
                source_note += "\n"
            skill_body = render_template(
                ROUTER_TEMPLATE,
                {
                    "NAME_JSON": json.dumps(name),
                    "DESCRIPTION_JSON": json.dumps(router_description),
                    "TITLE": router_title,
                    "SOURCE_NOTE": source_note,
                    "ROUTING_ROWS": "\n".join(routing_rows),
                },
            )

            staged = temporary_root / name
            staged.mkdir()
            references_dir = staged / "references"
            references_dir.mkdir()
            for skill_name in ordered:
                shutil.copytree(
                    source_dirs[skill_name],
                    references_dir / skill_name,
                    ignore=shutil.ignore_patterns(".git", GLOB_SOURCE_MARKER),
                )
                bundled_skill_file = references_dir / skill_name / "SKILL.md"
                if bundled_skill_file.exists():
                    bundled_skill_file.rename(references_dir / skill_name / "instructions.md")
            (staged / "SKILL.md").write_text(skill_body)

            if target.is_symlink() or target.is_file():
                target.unlink()
            elif target.exists():
                shutil.rmtree(target)
            shutil.copytree(staged, target)
        if absorb:
            self.absorb_router_sources(name, ordered)
        print(f"created router {name}: {len(ordered)} skills")

    def absorb_router_sources(self, router_name: str, skill_names: list[str]) -> None:
        for skill_name in skill_names:
            if skill_name == router_name:
                continue
            target = self.target(skill_name)
            if target.is_symlink() or target.is_file():
                target.unlink()
            elif target.exists():
                shutil.rmtree(target)

    def list(self) -> None:
        absorbed_names = self.absorbed_skill_names()
        # Determine which skill dirs are glob-owned
        glob_owned: set[str] = set()
        for label, source in self.sources.items():
            if _is_glob(source.get("path", "")):
                for skill_name in self._glob_owned_skills(label):
                    glob_owned.add(skill_name)

        names = set(self.sources) | set(self.routers)
        if self.skills_dir.exists():
            names.update(path.name for path in self.skills_dir.iterdir() if not path.name.startswith("."))

        for name in sorted(names):
            if name in self.routers:
                router = self.routers[name]
                count = len(router.get("absorbs", [])) if isinstance(router, dict) else 0
                detail = router.get("title", name) if isinstance(router, dict) else name
                if not self.target(name).exists():
                    detail += " (missing; run sync)"
                print(f"{name:<24} router    {detail} ({count} skills)")
                continue
            source = self.sources.get(name)
            # Glob source registry entries
            if source is not None and _is_glob(source.get("path", "")):
                owned = self._glob_owned_skills(name)
                n = len(owned)
                repo = source.get("repo", "<invalid>")
                pattern = source.get("path", "")
                if n == 0:
                    detail = f"{repo}:{pattern} (missing; run sync)"
                else:
                    detail = f"{repo}:{pattern} ({n} skills)"
                print(f"{name:<24} glob      {detail}")
                continue
            # Glob-owned skill dirs: skip (don't print as custom)
            if name in glob_owned:
                continue
            if name in absorbed_names:
                detail = source.get("repo", "<invalid>") if source else "absorbed"
                print(f"{name:<24} absorbed  {detail}")
                continue
            if source is None:
                print(f"{name:<24} custom")
                continue
            detail = source.get("repo", "<invalid>")
            if source.get("path"):
                detail += f":{source['path']}"
            else:
                detail += " (auto)"
            if not self.target(name).exists():
                detail += " (missing; run sync)"
            print(f"{name:<24} external  {detail}")

    def absorbed_skill_names(self) -> set[str]:
        absorbed: set[str] = set()
        for router in self.routers.values():
            if not isinstance(router, dict):
                continue
            absorbs = router.get("absorbs", [])
            if isinstance(absorbs, list):
                for spec in absorbs:
                    if isinstance(spec, str) and spec:
                        absorbed.add(_name_from_absorb(spec))
        return absorbed

    def check(self) -> None:
        errors: list[str] = []
        if not self.registry_path.exists():
            errors.append("skills.toml is missing")
        absorbed_names = self.absorbed_skill_names()

        # Determine which skill dirs are glob-owned
        glob_owned: set[str] = set()
        glob_labels: list[str] = []
        for label, source in sorted(self.sources.items()):
            if _is_glob(source.get("path", "")):
                glob_labels.append(label)
                for skill_name in self._glob_owned_skills(label):
                    glob_owned.add(skill_name)

        for name, source in sorted(self.sources.items()):
            errors.extend(self.validate_source(name, source))
            if name in absorbed_names:
                continue
            if _is_glob(source.get("path", "")):
                # For glob sources: require at least one owned skill
                if not self._glob_owned_skills(name):
                    errors.append(f"{name}: no glob-owned skills found; run skillctl sync {name}")
            else:
                target = self.target(name)
                if not target.exists():
                    errors.append(f"{name}: skills/{name} is missing; run skillctl sync {name}")
                elif target.is_symlink():
                    errors.append(f"{name}: external snapshot must not be a symlink")
        for name, router in sorted(self.routers.items()):
            errors.extend(self.validate_router_source(name, router))
            target = self.target(name)
            if not target.exists():
                errors.append(f"{name}: router is missing; run skillctl sync {name}")
                continue
            if not (target / "SKILL.md").is_file():
                errors.append(f"{name}: router SKILL.md is missing")
            if isinstance(router, dict) and isinstance(router.get("absorbs"), list):
                for spec in router["absorbs"]:
                    if not isinstance(spec, str) or not spec:
                        continue
                    skill_name = _name_from_absorb(spec)
                    reference = target / "references" / skill_name / "instructions.md"
                    if not reference.is_file():
                        errors.append(f"{name}: router reference missing: references/{skill_name}/instructions.md")

        if self.skills_dir.exists():
            for target in sorted(self.skills_dir.iterdir()):
                if target.name.startswith("."):
                    continue
                # Skip glob-owned dirs in the SKILL.md missing sweep
                if target.name in glob_owned:
                    continue
                if target.name in absorbed_names:
                    continue
                if not (target / "SKILL.md").is_file():
                    errors.append(f"{target.name}: SKILL.md is missing")

        if errors:
            raise SkillctlError("\n".join(errors))

        custom_count = 0
        glob_skill_count = 0
        router_count = len(self.routers)
        if self.skills_dir.exists():
            custom_count = sum(
                1
                for target in self.skills_dir.iterdir()
                if not target.name.startswith(".")
                and target.name not in self.sources
                and target.name not in self.routers
                and target.name not in glob_owned
            )
            glob_skill_count = len(glob_owned)

        external_count = sum(
            1 for s in self.sources.values() if not _is_glob(s.get("path", ""))
        )
        glob_source_count = len(glob_labels)

        if glob_source_count == 0:
            print(f"ok: {external_count} external skills, {router_count} routers, {custom_count} custom skills")
        else:
            print(
                f"ok: {external_count} external skills, "
                f"{router_count} routers, "
                f"{glob_source_count} glob sources ({glob_skill_count} skills), "
                f"{custom_count} custom skills"
            )


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--root", type=Path, default=Path(__file__).resolve().parent.parent)
    commands = parser.add_subparsers(dest="command", required=True)

    commands.add_parser("list", help="list external and custom skills")
    commands.add_parser("check", help="validate skills.toml and the skills tree")
    commands.add_parser("skills-sh", help="generate skills.sh.json from skills.toml routers")

    sync = commands.add_parser("sync", help="refresh registered external skill snapshots")
    sync.add_argument("names", nargs="*")

    add = commands.add_parser("add", help="register and sync an external skill")
    add.add_argument("source", help="owner/repo, git URL, or explicit skill name")
    add.add_argument("repo", nargs="?", help="repo when the first argument is an explicit name")
    add.add_argument("path", nargs="?", help="optional skill path inside the repo")
    add.add_argument("--ref", default="main")
    add.add_argument("--file", action="append", default=[])

    router = commands.add_parser("router", help="create a portable router skill")
    router.add_argument("name", help="new router skill name")
    router.add_argument("skills", nargs="*", help="installed skill names to bundle")
    router.add_argument("--group", help="include skills from a skills.sh.json grouping title")
    router.add_argument("--skills-sh", type=Path, default=Path("skills.sh.json"), help="skills.sh manifest path, relative to --root unless absolute")
    router.add_argument("--source-group", help="include skills owned by this glob source label")
    router.add_argument("--description", help="frontmatter description for the router skill")
    router.add_argument("--overwrite", action="store_true")
    router.add_argument("--absorb", action="store_true", help="remove selected top-level skill dirs after bundling them into the router")
    return parser


def main() -> int:
    args = build_parser().parse_args()
    try:
        manager = SkillManager(args.root)
        if args.command == "list":
            manager.list()
        elif args.command == "check":
            manager.check()
        elif args.command == "skills-sh":
            manager.write_skills_sh()
        elif args.command == "sync":
            manager.sync(args.names)
        elif args.command == "add":
            manager.add(args.source, args.repo, args.ref, args.path, args.file)
        elif args.command == "router":
            manager.router(
                args.name,
                args.skills,
                args.source_group,
                args.group,
                args.skills_sh,
                args.description,
                args.overwrite,
                args.absorb,
            )
    except SkillctlError as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
