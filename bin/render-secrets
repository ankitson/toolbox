#!/usr/bin/env python3
"""Render *.tmpl files containing 1Password references into a secrets dir.

For each template TEMPLATE_DIR/<name>.tmpl, writes SECRETS_DIR/<name> with every
`{{ op://... }}` reference resolved via `op inject`. Output files are written
with restrictive permissions (default 0600) into a 0700 secrets dir.

1Password auth is taken from the ambient environment (OP_SERVICE_ACCOUNT_TOKEN
or a configured `op` account); run this as the user who owns that config.

Examples:
  render-secrets                          # config/*.tmpl -> secrets/*
  render-secrets --strict                 # exit non-zero if no templates found
  render-secrets cfg out                  # custom dirs (positional)
  render-secrets --pattern '*.env.tmpl'   # restrict which templates render
"""
from __future__ import annotations

import argparse
import subprocess
import sys
from pathlib import Path


def main() -> int:
    ap = argparse.ArgumentParser(
        prog="render-secrets",
        description="Render config/*.tmpl -> secrets/* using `op inject`.",
    )
    ap.add_argument("template_dir", nargs="?", default="config",
                    help="directory holding *.tmpl files (default: config)")
    ap.add_argument("secrets_dir", nargs="?", default="secrets",
                    help="output directory for rendered secrets (default: secrets)")
    ap.add_argument("--pattern", action="append", metavar="GLOB",
                    help="template glob(s) to render (repeatable; default: *.tmpl)")
    ap.add_argument("--mode", default="600",
                    help="octal mode for rendered files (default: 600)")
    ap.add_argument("--strict", action="store_true",
                    help="exit non-zero if the template dir or matches are missing")
    ap.add_argument("--skip-existing", action="store_true",
                    help="leave already-rendered outputs untouched instead of overwriting")
    args = ap.parse_args()

    template_dir = Path(args.template_dir)
    secrets_dir = Path(args.secrets_dir)
    patterns = args.pattern or ["*.tmpl"]
    file_mode = int(args.mode, 8)

    def bail(msg: str) -> int:
        if args.strict:
            print(msg, file=sys.stderr)
            return 1
        print(msg + "; skipping render.")
        return 0

    if not template_dir.is_dir():
        return bail(f"render-secrets: template dir not found: {template_dir}")

    templates = sorted({t for pat in patterns for t in template_dir.glob(pat)})
    if not templates:
        return bail(f"render-secrets: no templates in {template_dir} matching {patterns}")

    secrets_dir.mkdir(parents=True, exist_ok=True)
    try:
        secrets_dir.chmod(0o700)
    except OSError:
        pass

    for tmpl in templates:
        out = secrets_dir / tmpl.name.removesuffix(".tmpl")  # foo.env.tmpl -> foo.env
        if args.skip_existing and out.exists():
            print(f"Skipping {out} (already exists)")
            continue
        print(f"Rendering {tmpl} -> {out}")
        result = subprocess.run(["op", "inject", "--force", "-i", str(tmpl), "-o", str(out)])
        if result.returncode != 0:
            print(
                f"render-secrets: `op inject` failed for {tmpl} (exit {result.returncode}). "
                "Check that op is authenticated and can read its op:// references.",
                file=sys.stderr,
            )
            return result.returncode
        try:
            out.chmod(file_mode)
        except OSError:
            pass

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
