#!/usr/bin/env python3
"""Open this machine's current directory in VS Code Insiders on Windows."""

from __future__ import annotations

import argparse
import base64
import re
import os
import socket
import subprocess
import sys
import xml.etree.ElementTree as ET
from pathlib import Path


DEFAULT_WINDOWS_HOST = "ts-desktop-win"
WINDOWS_HOST_ENV = "CODE_INSIDERS_WINDOWS_HOST"
REMOTE_TARGET_ENV = "CODE_INSIDERS_REMOTE_TARGET"
CLIXML_CODEPOINT = re.compile(r"_x([0-9A-Fa-f]{4})_")


class CliError(RuntimeError):
    """An expected user-facing failure."""


def ps_quote(value: str) -> str:
    return "'" + value.replace("'", "''") + "'"


def logical_cwd() -> Path:
    pwd = os.environ.get("PWD")
    if pwd:
        candidate = Path(pwd).expanduser()
        if candidate.is_absolute():
            try:
                if candidate.resolve() == Path.cwd().resolve():
                    return candidate
            except OSError:
                pass
    return Path.cwd()


def target_path(path: str | None) -> str:
    base = logical_cwd()
    if not path:
        return str(base)

    candidate = Path(path).expanduser()
    if not candidate.is_absolute():
        candidate = base / candidate
    return str(candidate)


def default_remote_target() -> str:
    return os.environ.get(REMOTE_TARGET_ENV) or socket.gethostname()


def powershell_script(remote_target: str, remote_path: str, window_flag: str | None) -> str:
    remote_name = f"ssh-remote+{remote_target}"
    window_arg = f"$arguments += {ps_quote(window_flag)}" if window_flag else ""
    return f"""$ErrorActionPreference = 'Stop'
$ProgressPreference = 'SilentlyContinue'
$remoteName = {ps_quote(remote_name)}
$remotePath = {ps_quote(remote_path)}
$candidates = @()

if ($env:LOCALAPPDATA) {{
    $candidates += Join-Path $env:LOCALAPPDATA 'Programs\\Microsoft VS Code Insiders\\Code - Insiders.exe'
    $candidates += Join-Path $env:LOCALAPPDATA 'Programs\\Microsoft VS Code Insiders\\bin\\code-insiders.cmd'
}}
if ($env:ProgramFiles) {{
    $candidates += Join-Path $env:ProgramFiles 'Microsoft VS Code Insiders\\Code - Insiders.exe'
    $candidates += Join-Path $env:ProgramFiles 'Microsoft VS Code Insiders\\bin\\code-insiders.cmd'
}}
if (${{env:ProgramFiles(x86)}}) {{
    $candidates += Join-Path ${{env:ProgramFiles(x86)}} 'Microsoft VS Code Insiders\\Code - Insiders.exe'
    $candidates += Join-Path ${{env:ProgramFiles(x86)}} 'Microsoft VS Code Insiders\\bin\\code-insiders.cmd'
}}

$cmd = Get-Command 'Code - Insiders.exe' -ErrorAction SilentlyContinue
if ($cmd) {{ $candidates += $cmd.Source }}

$cmd = Get-Command 'code-insiders.cmd' -ErrorAction SilentlyContinue
if ($cmd) {{ $candidates += $cmd.Source }}

$cmd = Get-Command 'code-insiders' -ErrorAction SilentlyContinue
if ($cmd) {{ $candidates += $cmd.Source }}

$code = $candidates |
    Where-Object {{ $_ -and (Test-Path -LiteralPath $_) }} |
    Select-Object -First 1

if (-not $code) {{
    throw 'Could not find Code - Insiders.exe or code-insiders.cmd on the Windows host. Install VS Code Insiders or add its bin directory to PATH.'
}}

function Quote-CommandArgument([string]$value) {{
    '"' + ($value -replace '"', '\\"') + '"'
}}

$arguments = @()
{window_arg}
$arguments += '--remote'
$arguments += $remoteName
$arguments += $remotePath
$argumentString = ($arguments | ForEach-Object {{ Quote-CommandArgument $_ }}) -join ' '
$taskName = 'wined-' + [Guid]::NewGuid().ToString('N')
$identity = [System.Security.Principal.WindowsIdentity]::GetCurrent().Name

try {{
    $action = New-ScheduledTaskAction -Execute $code -Argument $argumentString
    $principal = New-ScheduledTaskPrincipal -UserId $identity -LogonType Interactive -RunLevel Limited
    $settings = New-ScheduledTaskSettingsSet -AllowStartIfOnBatteries -ExecutionTimeLimit (New-TimeSpan -Minutes 5)
    Register-ScheduledTask -TaskName $taskName -Action $action -Principal $principal -Settings $settings -Force | Out-Null
    Start-ScheduledTask -TaskName $taskName
    Start-Sleep -Seconds 2
}} finally {{
    Unregister-ScheduledTask -TaskName $taskName -Confirm:$false -ErrorAction SilentlyContinue
}}
"""


def encoded_powershell(script: str) -> str:
    return base64.b64encode(script.encode("utf-16le")).decode("ascii")


def decode_clixml_text(text: str) -> str:
    def replace_codepoint(match: re.Match[str]) -> str:
        return chr(int(match.group(1), 16))

    return CLIXML_CODEPOINT.sub(replace_codepoint, text)


def clean_powershell_output(text: str) -> str:
    text = text.strip()
    if not text.startswith("#< CLIXML"):
        return text

    xml_start = text.find("<Objs")
    if xml_start == -1:
        return decode_clixml_text(text)

    try:
        root = ET.fromstring(text[xml_start:])
    except ET.ParseError:
        return decode_clixml_text(text)

    messages: list[str] = []
    for element in root.iter():
        if element.tag.endswith("S") and element.text:
            messages.append(decode_clixml_text(element.text))
    return "".join(messages).strip() or decode_clixml_text(text)


def build_ssh_command(args: argparse.Namespace) -> list[str]:
    remote_path = target_path(args.path)
    window_flag = "--new-window" if args.new_window else "--reuse-window" if args.reuse_window else None
    script = powershell_script(args.remote_target, remote_path, window_flag)
    return [
        "ssh",
        *args.ssh_option,
        args.windows_host,
        "powershell.exe",
        "-NoLogo",
        "-NoProfile",
        "-NonInteractive",
        "-OutputFormat",
        "Text",
        "-ExecutionPolicy",
        "Bypass",
        "-EncodedCommand",
        encoded_powershell(script),
    ]


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Launch VS Code Insiders on a Windows SSH host and open a Remote-SSH "
            "window for this machine."
        )
    )
    parser.add_argument(
        "path",
        nargs="?",
        help="Remote path to open on this machine. Defaults to the current directory.",
    )
    parser.add_argument(
        "-w",
        "--windows-host",
        default=os.environ.get(WINDOWS_HOST_ENV, DEFAULT_WINDOWS_HOST),
        help=(
            "SSH host for the Windows machine. Defaults to "
            f"${WINDOWS_HOST_ENV} or {DEFAULT_WINDOWS_HOST!r}."
        ),
    )
    parser.add_argument(
        "-t",
        "--remote-target",
        default=default_remote_target(),
        help=(
            "Remote-SSH target name for this machine as configured in VS Code "
            f"on Windows. Defaults to ${REMOTE_TARGET_ENV} or this hostname."
        ),
    )
    parser.add_argument(
        "-n",
        "--new-window",
        action="store_true",
        help="Ask VS Code Insiders to open a new window.",
    )
    parser.add_argument(
        "-r",
        "--reuse-window",
        action="store_true",
        help="Ask VS Code Insiders to reuse an existing window.",
    )
    parser.add_argument(
        "-o",
        "--ssh-option",
        action="append",
        default=[],
        metavar="OPTION",
        help="Additional option passed to ssh before the Windows host. Repeat as needed.",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print the ssh command without running it.",
    )
    args = parser.parse_args(argv)
    if args.new_window and args.reuse_window:
        raise CliError("choose only one of --new-window or --reuse-window")
    return args


def main(argv: list[str]) -> int:
    try:
        args = parse_args(argv)
        command = build_ssh_command(args)
        if args.dry_run:
            print(" ".join(command))
            return 0
        completed = subprocess.run(
            command,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
        )
        if completed.returncode != 0:
            output = clean_powershell_output("\n".join((completed.stdout, completed.stderr)))
            if output:
                print(output, file=sys.stderr)
            return completed.returncode
    except CliError as exc:
        print(f"wined: {exc}", file=sys.stderr)
        return 2
    except FileNotFoundError:
        print("wined: ssh was not found on PATH", file=sys.stderr)
        return 127
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
